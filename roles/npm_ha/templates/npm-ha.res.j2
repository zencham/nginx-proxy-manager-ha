  on {{ node1_hostname }} {
    device {{ drbd_device_db }};
    disk {{ drbd_disk_db }};
    address {{ node1_ip }}:{{ drbd_port_db }};
  }
  on {{ node2_hostname }} {
    device {{ drbd_device_db }};
    disk {{ drbd_disk_db }};
    address {{ node2_ip }}:{{ drbd_port_db }};
  }
}
