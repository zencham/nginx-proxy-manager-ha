---
exclude_paths:
  - roles/npm_ha/molecule/

skip_list:
  # Renaming all role variables to an npm_ha_* prefix and fully qualifying
  # every builtin module action (ansible.builtin.*) are large mechanical
  # refactors touching nearly every file in the role. Tracked as future
  # work, not part of this hardening pass.
  - var-naming[no-role-prefix]
  - fqcn[action-core]
  - fqcn[action]
  # pcs/drbdadm command tasks are gated by `when` checks for idempotency;
  # changed_when:false would misreport real cluster/resource changes as "ok".
  - no-changed-when
  # The DRBD init flow intentionally chains several follow-on tasks off one
  # registered result (drbd_init) rather than restructuring into handlers.
  - no-handler
  # `drbdadm up all` returns non-zero for resources that are already up —
  # this is benign and expected on re-runs.
  - ignore-errors
  # `pcs status ... | grep <resource>` is the documented pattern for polling
  # cluster/resource state.
  - risky-shell-pipe
