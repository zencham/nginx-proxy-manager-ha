#!/usr/bin/env bash
set -euo pipefail

# Resolve repo root (script's own dir) so ansible.cfg is always found.
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DRY_RUN="${NPMCTL_DRY_RUN:-0}"

# ANSI palette — disabled when not a TTY or NO_COLOR is set.
if [[ -t 1 && -z "${NO_COLOR:-}" ]]; then
  C_RESET=$'\e[0m'; C_BOLD=$'\e[1m'; C_DIM=$'\e[2m'
  C_RED=$'\e[31m'; C_GREEN=$'\e[32m'; C_YEL=$'\e[33m'; C_BLU=$'\e[34m'; C_CYN=$'\e[36m'
else
  C_RESET=''; C_BOLD=''; C_DIM=''; C_RED=''; C_GREEN=''; C_YEL=''; C_BLU=''; C_CYN=''
fi

# --- output helpers ---
die()  { printf 'error: %s\n' "$*" >&2; exit 1; }
warn() { printf 'warning: %s\n' "$*" >&2; }
info() { printf '%s\n' "$*"; }

# run <cmd...> : execute, or under dry-run print what would run.
run() {
  if [[ "$DRY_RUN" == "1" ]]; then
    printf 'would-run: %s\n' "$*"
    return 0
  fi
  "$@"
}

# run_step <label> <cmd...> : spinner while running on a TTY, then ✓/✗ + elapsed.
# Honors dry-run (prints "would-run: <cmd>") and non-TTY (plain lines). Returns rc.
run_step() {
  local label="$1"; shift
  if [[ "$DRY_RUN" == "1" ]]; then printf 'would-run: %s\n' "$*"; return 0; fi
  local log rc start=$SECONDS; log="$(mktemp)"
  if [[ -t 1 ]]; then
    ( "$@" >"$log" 2>&1 ) & local pid=$! i=0
    local frames='⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏'
    tput civis >/dev/tty 2>/dev/null || true
    while kill -0 "$pid" 2>/dev/null; do
      printf '\r%s%s%s %s' "$C_CYN" "${frames:i++%10:1}" "$C_RESET" "$label" >/dev/tty
      sleep 0.1
    done
    wait "$pid"; rc=$?
    tput cnorm >/dev/tty 2>/dev/null || true
    printf '\r\033[K' >/dev/tty
  else
    printf '• %s\n' "$label"; "$@" >"$log" 2>&1; rc=$?
  fi
  local secs=$(( SECONDS - start ))
  if (( rc == 0 )); then printf '%s✓%s %s (%ss)\n' "$C_GREEN" "$C_RESET" "$label" "$secs"
  else printf '%s✗%s %s (rc %s)\n' "$C_RED" "$C_RESET" "$label" "$rc"; tail -n 15 "$log"; fi
  rm -f "$log"; return "$rc"
}

# --- command functions (filled in by later tasks) ---
cmd_help() {
  cat <<'EOF'
npmctl — manage the NPM HA cluster

Usage: npmctl <command> [flags]
       npmctl              (no args: interactive menu)

Commands:
  deploy        Safe converge: drift-check + backup, then main.yml, then verify
  drift         Check repo vs live config drift
  backup        Snapshot NPM proxy hosts
  verify        Verify proxy hosts against the snapshot
  restore       Restore missing proxy hosts from the snapshot
  update        Rolling NPM image update
  cert          Issue/renew TLS certificates
  status        Show cluster / DRBD / VIP health
  logs          Tail NPM container logs
  vault-edit    Edit an encrypted vault (ha_nodes|controller)
  help          Show this help
EOF
}

cmd_drift()   { run_step "drift check"          ansible-playbook drift_check.yml "$@"; }
cmd_backup()  { run_step "snapshot proxy hosts" ansible-playbook proxy_backup.yml "$@"; }
cmd_verify()  { run_step "verify proxy hosts"   ansible-playbook proxy_verify.yml "$@"; }
cmd_restore() { run_step "restore proxy hosts"  ansible-playbook proxy_restore.yml "$@"; }
cmd_update()  { run_step "rolling update"       ansible-playbook npm_update.yml "$@"; }
cmd_cert()    { run_step "issue/renew certs"    ansible-playbook cert_manager.yml "$@"; }

# confirm_or_die <message> : interactive yes/no. Honors --yes (FORCE_YES) and dry-run.
FORCE_YES=0
confirm_or_die() {
  local msg="$1"
  if [[ "$FORCE_YES" == "1" ]]; then
    [[ "$DRY_RUN" == "1" ]] && printf 'confirm-skipped: %s\n' "$msg"
    return 0
  fi
  if [[ "$DRY_RUN" == "1" ]]; then
    printf 'would-confirm: %s\n' "$msg"; return 0
  fi
  local ans
  read -r -p "$msg [y/N] " ans
  [[ "$ans" == "y" || "$ans" == "Y" ]] || die "aborted by operator"
}

cmd_main() { run_step "converge (main.yml)" ansible-playbook main.yml "$@"; }

# VIP/admin port: parsed from group_vars with documented fallbacks.
_vip() {  sed -nE 's/^vip_address:[[:space:]]*"?([0-9.]+)"?.*/\1/p' inventory/group_vars/ha_nodes/vars.yml 2>/dev/null | head -1; }
_port() { sed -nE 's/^npm_admin_port:[[:space:]]*"?([0-9]+)"?.*/\1/p'   inventory/group_vars/ha_nodes/vars.yml 2>/dev/null | head -1; }

# Known cluster nodes (from group_vars, with MIBTECH fallback in _node_full).
_node1() { sed -nE 's/^node1_name:[[:space:]]*"?([A-Za-z0-9.-]+)"?.*/\1/p' inventory/group_vars/ha_nodes/vars.yml 2>/dev/null | head -1; }
_node2() { sed -nE 's/^node2_name:[[:space:]]*"?([A-Za-z0-9.-]+)"?.*/\1/p' inventory/group_vars/ha_nodes/vars.yml 2>/dev/null | head -1; }

# _node_short <full> : MIBTECH-NPM-PROD-01 -> PROD-01 (else echo input unchanged).
_node_short() {
  local n="$1"
  if [[ "$n" =~ (PROD-[0-9]+)$ ]]; then printf '%s' "${BASH_REMATCH[1]}"; else printf '%s' "$n"; fi
}

# _node_full <short|full> : resolve to a canonical full cluster node name, or rc 1.
_node_full() {
  local arg="$1" n1 n2; n1="$(_node1)"; n2="$(_node2)"
  n1="${n1:-MIBTECH-NPM-PROD-01}"; n2="${n2:-MIBTECH-NPM-PROD-02}"
  case "$arg" in
    "$n1"|"$(_node_short "$n1")") printf '%s' "$n1" ;;
    "$n2"|"$(_node_short "$n2")") printf '%s' "$n2" ;;
    *) return 1 ;;
  esac
}

# _parse_nodes <pcs-status-nodes-text> <active-full> : emit "state<TAB>icon short  ROLE".
# state: ok=active, bad=standby (reduced redundancy), dim=passive online.
_parse_nodes() {
  local text="$1" active="$2" n short standby_line
  standby_line="$(printf '%s\n' "$text" | grep -E '^ *Standby:' | head -1)"
  for n in "$(_node1)" "$(_node2)"; do
    [[ -z "$n" ]] && continue
    short="$(_node_short "$n")"
    if [[ "$n" == "$active" ]]; then printf 'ok\t● %s  ACTIVE\n' "$short"
    elif printf '%s' "$standby_line" | grep -qF "$n"; then printf 'bad\t⊘ %s  STANDBY\n' "$short"
    else printf 'dim\t○ %s  passive\n' "$short"; fi
  done
}

# _parse_drbd <text> : emit "ok|bad<TAB>app|db<TAB>detail" per DRBD minor (10=app,11=db).
_parse_drbd() {
  local text="$1" line label st cs ds
  while IFS= read -r line; do
    case "$line" in
      10:*) label=app ;;
      11:*) label=db ;;
      *) continue ;;
    esac
    if [[ "$line" == *cs:Connected* && "$line" == *ds:UpToDate/UpToDate* ]]; then st=ok; else st=bad; fi
    cs="$(printf '%s\n' "$line" | grep -oE 'cs:[A-Za-z]+' | head -1)"
    ds="$(printf '%s\n' "$line" | grep -oE 'ds:[A-Za-z]+/[A-Za-z]+' | head -1)"
    printf '%s\t%s\t%s %s\n' "$st" "$label" "${cs#cs:}" "${ds#ds:}"
  done <<< "$text"
}

# _parse_pcs <text> : emit "ok|bad<TAB>name<TAB>detail" for npm_vip / npm_service,
# plus "bad<TAB>failed-actions<TAB>present" if Failed Resource Actions appear.
_parse_pcs() {
  local text="$1" line name st detail node
  for name in npm_vip npm_service; do
    line="$(printf '%s\n' "$text" | grep -F "$name" | head -1)"
    [[ -z "$line" ]] && continue
    if [[ "$line" == *Started* ]]; then
      node="$(printf '%s\n' "$line" | grep -oE 'MIBTECH-[A-Z0-9-]+' | head -1)"
      st=ok; detail="Started ${node}"
    else
      detail="$(printf '%s\n' "$line" | grep -oE 'Stopped|FAILED|Starting' | head -1)"
      st=bad; detail="${detail:-down}"
    fi
    printf '%s\t%s\t%s\n' "$st" "$name" "$detail"
  done
  if printf '%s\n' "$text" | grep -q 'Failed Resource Actions'; then
    printf 'bad\tfailed-actions\tpresent\n'
  fi
}

# _row <ok|bad|''> <label> <detail> : indented "✓ label  detail" / "✗ …" for a
# check, or a plain group heading when status is empty. Color via palette.
_row() {
  local st="$1" label="$2" detail="$3"
  case "$st" in
    ok)  printf '  %s✓%s %s%s' "$C_GREEN" "$C_RESET" "$label" "${detail:+ $detail}" ;;
    bad) printf '  %s✗%s %s%s' "$C_RED"   "$C_RESET" "$label" "${detail:+ $detail}" ;;
    *)   printf '%s' "$label" ;;
  esac
}

cmd_status() {
  local vip port; vip="$(_vip)"; vip="${vip:-192.168.206.220}"; port="$(_port)"; port="${port:-15625}"
  if [[ "$DRY_RUN" == "1" ]]; then
    run ansible ha_nodes -b -m shell -a 'grep -E "^ *[0-9]+:" /proc/drbd'
    return 0
  fi
  local drbd_raw pcs_raw http out=() bad=0 st label detail
  # Tight per-resource signature (cs:WORD ro:W/W ds:W/W); keep one row per minor
  # (app=10, db=11). awk '!seen[$1]++' takes the first occurrence across both nodes.
  drbd_raw="$(ansible ha_nodes -b -o -m shell -a 'grep -E "^ *[0-9]+:" /proc/drbd' 2>/dev/null \
              | grep -oE '1[01]: cs:[A-Za-z]+ ro:[A-Za-z]+/[A-Za-z]+ ds:[A-Za-z]+/[A-Za-z]+' \
              | awk '!seen[$1]++')"
  pcs_raw="$(ansible ha_nodes -b -o -m shell -a 'pcs status --full | grep -E "npm_service|npm_vip|Failed Resource"' 2>/dev/null)"
  http="$(curl -s -o /dev/null -w '%{http_code}' --max-time 8 "http://${vip}:${port}/" 2>/dev/null || echo 000)"

  out+=( 'DRBD' )
  while IFS=$'\t' read -r st label detail; do
    [[ -z "$st" ]] && continue
    [[ "$st" == bad ]] && bad=$((bad+1))
    out+=( "$(_row "$st" "$(printf '%-11s' "$label")" "$detail")" )
  done <<< "$(_parse_drbd "$drbd_raw")"

  out+=( 'Pacemaker' )
  while IFS=$'\t' read -r st label detail; do
    [[ -z "$st" ]] && continue
    [[ "$st" == bad ]] && bad=$((bad+1))
    out+=( "$(_row "$st" "$(printf '%-11s' "$label")" "$detail")" )
  done <<< "$(_parse_pcs "$pcs_raw")"

  out+=( "VIP ${vip}:${port}" )
  if [[ "$http" == 2* || "$http" == 3* ]]; then out+=( "$(_row ok "$(printf '%-11s' HTTP)" "$http")" )
  else out+=( "$(_row bad "$(printf '%-11s' HTTP)" "$http")" ); bad=$((bad+1)); fi

  if (( bad == 0 )); then out+=( "$(_row ok '' 'healthy')" )
  else out+=( "$(_row bad '' "$bad issue(s)")" ); fi

  ui_box 'Cluster Health' "${out[@]}"
  (( bad == 0 ))
}

cmd_logs() {
  local n="${1:-50}"
  run ansible ha_nodes -b -m shell -a "docker compose -f /opt/npm/compose/docker-compose.yml logs --tail=${n} 2>/dev/null || true"
}

cmd_vault_edit() {
  local target="${1:-}"
  case "$target" in
    ha_nodes)   run ansible-vault edit inventory/group_vars/ha_nodes/vault.yml ;;
    controller) run ansible-vault edit inventory/group_vars/controller/vault.yml ;;
    *) die "vault-edit: target must be ha_nodes or controller" ;;
  esac
}

cmd_deploy() {
  local force=0
  FORCE_YES=0
  for arg in "$@"; do
    case "$arg" in
      --force) force=1 ;;
      --yes)   FORCE_YES=1 ;;
      *) die "deploy: unknown flag $arg" ;;
    esac
  done

  info "[1/5] drift check"
  if [[ "$force" == "1" ]]; then info "drift gate bypassed (--force)"; fi
  if ! cmd_drift && [[ "$force" != "1" ]]; then
    die "drift detected — reconcile repo vs live, or re-run with --force"
  fi

  info "[2/5] snapshot proxy hosts"
  cmd_backup

  info "[3/5] confirm"
  confirm_or_die "About to converge PRODUCTION (main.yml). Continue?"

  info "[4/5] converge"
  cmd_main

  info "[5/5] verify proxy hosts survived"
  cmd_verify
}

# --- dispatch ---
dispatch() {
  local cmd="${1:-}"; shift || true
  case "$cmd" in
    help|-h|--help) cmd_help ;;
    drift)   cmd_drift "$@" ;;
    backup)  cmd_backup "$@" ;;
    verify)  cmd_verify "$@" ;;
    restore) cmd_restore "$@" ;;
    update)  cmd_update "$@" ;;
    cert)    cmd_cert "$@" ;;
    deploy)  cmd_deploy "$@" ;;
    status)     cmd_status "$@" ;;
    logs)       cmd_logs "$@" ;;
    vault-edit) cmd_vault_edit "$@" ;;
    *) printf 'Usage: npmctl <command>\nUnknown command: %s\n' "$cmd" >&2; cmd_help >&2; return 2 ;;
  esac
}

# Restore cursor/colors on exit or Ctrl-C, but only on a real TTY — otherwise
# tput would emit escape bytes into piped/captured output (e.g. `npmctl status | grep`).
_restore_term() {
  [[ -t 1 ]] || return 0
  tput cnorm 2>/dev/null || true
  printf '%s' "${C_RESET:-}"
}
trap _restore_term EXIT INT

# _vlen <text> : visible character width (strips ANSI; counts code points, correct
# for non-wide glyphs in a UTF-8 locale) so colored/Unicode content aligns.
_vlen() {
  local esc s
  esc="$(printf '\033')"
  s="$(printf '%s' "$1" | sed "s/${esc}\[[0-9;]*m//g")"
  printf '%s' "${#s}"
}

# ui_box <title> <line>... : rounded box sized to the widest visible line.
# NPMCTL_ASCII=1 falls back to ASCII corners for terminals without box glyphs.
ui_box() {
  local title="$1"; shift
  local lines=("$@") w i len
  w="$(_vlen "$title")"
  for i in "${lines[@]}"; do len="$(_vlen "$i")"; (( len > w )) && w=$len; done
  (( w += 2 ))
  local tl='╭' tr='╮' bl='╰' br='╯' h='─' v='│'
  if [[ -n "${NPMCTL_ASCII:-}" ]]; then tl='+'; tr='+'; bl='+'; br='+'; h='-'; v='|'; fi
  local topfill bar pad n
  topfill=''; for (( n = w - ${#title} - 3; n > 0; n-- )); do topfill+="$h"; done
  bar='';     for (( n = w; n > 0; n-- )); do bar+="$h"; done
  printf '%s%s%s %s %s%s%s\n' "$C_CYN" "$tl" "$h" "$title" "$topfill" "$tr" "$C_RESET"
  for i in "${lines[@]}"; do
    pad=$(( w - 2 - $(_vlen "$i") )); (( pad < 0 )) && pad=0
    printf '%s%s%s %s%*s %s%s%s\n' "$C_CYN" "$v" "$C_RESET" "$i" "$pad" '' "$C_CYN" "$v" "$C_RESET"
  done
  printf '%s%s%s%s%s\n' "$C_CYN" "$bl" "$bar" "$br" "$C_RESET"
}

ui_banner() { ui_box 'NPM HA · MIBTECH' 'npmctl — cluster management'; }

# ui_menu <prompt> <item1> ... : draws to /dev/tty and reads keys from /dev/tty so
# the ONLY thing on stdout is the chosen item. Items beginning with "--" are
# non-selectable section headings (skipped by arrow nav). An optional parallel
# UI_DESC array (indexed like items) prints a dim description per row.
ui_menu() {
  local prompt="$1"; shift
  local items=("$@") sel=0 key i it desc
  # advance sel by direction d to the next selectable (non-"--") row; no-op at ends.
  _sel_next() { local d="$1" n=$sel; while :; do n=$((n+d)); ((n<0||n>=${#items[@]})) && return 1; [[ "${items[$n]}" == --* ]] || { sel=$n; return 0; }; done; }
  [[ "${items[0]}" == --* ]] && _sel_next 1
  tput civis >/dev/tty 2>/dev/null || true
  while true; do
    printf '%s%s%s\n' "$C_BOLD" "$prompt" "$C_RESET" >/dev/tty
    for i in "${!items[@]}"; do
      it="${items[$i]}"; desc="${UI_DESC[$i]:-}"
      if [[ "$it" == --* ]]; then
        printf '  %s%s%s\n' "$C_DIM" "${it#--}" "$C_RESET" >/dev/tty
      elif [[ "$i" == "$sel" ]]; then
        printf '  %s› %-11s%s %s%s%s\n' "$C_GREEN" "$it" "$C_RESET" "$C_DIM" "$desc" "$C_RESET" >/dev/tty
      else
        printf '    %-11s %s%s%s\n' "$it" "$C_DIM" "$desc" "$C_RESET" >/dev/tty
      fi
    done
    IFS= read -rsn1 key </dev/tty
    if [[ "$key" == $'\e' ]]; then read -rsn2 -t 0.001 key </dev/tty || true
      case "$key" in '[A') _sel_next -1 || true;; '[B') _sel_next 1 || true;; esac
    elif [[ "$key" == "" ]]; then [[ "${items[$sel]}" == --* ]] || break
    fi
    printf '\e[%dA' "$(( ${#items[@]} + 1 ))" >/dev/tty
  done
  tput cnorm >/dev/tty 2>/dev/null || true
  printf '%s' "${items[$sel]}"
}

interactive_menu() {
  local choice t items UI_DESC
  while true; do
    clear 2>/dev/null || true
    ui_banner
    items=( '--Operate' deploy drift '--Inspect' status logs
            '--Maintain' backup verify restore update cert vault-edit quit )
    UI_DESC=( '' 'safe converge (gate→backup→verify)' 'check repo vs live config'
              '' 'cluster / DRBD / VIP health' 'tail NPM container logs'
              '' 'snapshot proxy hosts' 'verify proxy hosts' 'restore proxy hosts'
              'rolling image update' 'issue/renew TLS' 'edit secrets' 'exit' )
    choice="$(ui_menu 'Choose an action:' "${items[@]}")"
    [[ "$choice" == "quit" ]] && break
    printf '\n'
    if [[ "$choice" == "vault-edit" ]]; then
      UI_DESC=(); t="$(ui_menu 'Which vault?' 'ha_nodes' 'controller')"; dispatch vault-edit "$t" || true
    else
      dispatch "$choice" || warn "command '$choice' failed (rc $?)"
    fi
    printf '\n%sPress Enter to return to the menu…%s' "$C_DIM" "$C_RESET"; read -r
  done
}

main() {
  cd "$SCRIPT_DIR"
  [[ -f ansible.cfg ]] || die "must be run from the project root (ansible.cfg not found)"
  [[ -f .vault_pass ]] || warn ".vault_pass not found — vault-backed commands will fail until you create it"
  if [[ $# -eq 0 ]]; then
    if [[ -t 0 && -t 1 ]]; then
      interactive_menu
    else
      printf 'Usage: npmctl <command>  (interactive menu needs a TTY)\n' >&2
      cmd_help >&2
      return 2
    fi
  else
    dispatch "$@"
  fi
}

# Run main only when executed directly; when sourced (tests access functions in
# isolation) skip it so sourcing has no side effects.
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
